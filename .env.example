# BOT_ROLE: en_teacher or ja_teacher
# Use a separate .env file per bot when running 2 services
# (e.g. .env.en for the English-teacher bot, .env.ja for the Japanese-teacher bot).
BOT_ROLE=en_teacher

DISCORD_BOT_TOKEN=your_bot_token_here
GEMINI_API_KEY=your_gemini_api_key_here

# REPORT_CHANNEL_ID / QUIZ_CHANNEL_ID are PER-BOT. Each bot's .env file holds the
# channel ID dedicated to that bot's target language (English-teacher → English
# quiz/report channel, Japanese-teacher → Japanese quiz/report channel). Run
# different .env files per bot so each posts only to its own channel.
REPORT_CHANNEL_ID=your_report_channel_id_here
QUIZ_CHANNEL_ID=your_quiz_channel_id_here

# Learner identities. Both bots read both pairs (the report can reference both
# learners), but only the learner matching BOT_ROLE is the active user of this bot.
EN_LEARNER_NAME=English learner name (e.g. Chris)
EN_LEARNER_DISCORD_ID=your_en_learner_discord_user_id_here
JA_LEARNER_NAME=Japanese learner name (e.g. Camille)
JA_LEARNER_DISCORD_ID=your_ja_learner_discord_user_id_here
